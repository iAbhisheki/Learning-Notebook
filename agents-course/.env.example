# ===========================================
# Environment Configuration
# ===========================================
# Copy this file to .env and fill in your keys
# You only need ONE provider to get started!

# --- OpenAI ---
OPENAI_API_KEY=sk-your-openai-key-here

# --- Google Gemini ---
GOOGLE_API_KEY=your-google-api-key-here

# --- Anthropic Claude ---
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# --- Default Model (change this to switch providers) ---
# OpenAI:     gpt-4o-mini, gpt-4o, gpt-4-turbo
# Gemini:     gemini/gemini-2.0-flash, gemini/gemini-2.0-flash-lite
# Claude:     claude-3-haiku-20240307, claude-3-5-sonnet-20241022
DEFAULT_MODEL=gpt-4o-mini

# --- Default Embedding Model ---
# OpenAI:     text-embedding-3-small, text-embedding-3-large
# Gemini:     gemini/text-embedding-004
DEFAULT_EMBEDDING_MODEL=text-embedding-3-small

# --- LangSmith (Optional — for NB21, NB24, Capstone 4) ---
# Get your key at https://smith.langchain.com
LANGCHAIN_API_KEY=ls-your-langsmith-key-here
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=agents-course
