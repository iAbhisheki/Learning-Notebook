# ===========================================
# Environment Configuration
# ===========================================
# Copy this file to .env and fill in your keys
# You only need ONE provider to get started!

# --- OpenAI ---
OPENAI_API_KEY=sk-your-openai-key-here

# --- Google Gemini ---
GOOGLE_API_KEY=your-google-api-key-here

# --- Anthropic Claude ---
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# --- Default Model (change this to switch providers) ---
# OpenAI:     gpt-4o-mini, gpt-4o, gpt-4-turbo
# Gemini:     gemini/gemini-2.0-flash, gemini/gemini-2.0-flash-lite
# Claude:     claude-3-haiku-20240307, claude-3-5-sonnet-20241022
DEFAULT_MODEL=gpt-4o-mini

# --- Default Embedding Model ---
# OpenAI:     text-embedding-3-small, text-embedding-3-large
# Gemini:     gemini/text-embedding-004
DEFAULT_EMBEDDING_MODEL=text-embedding-3-small

# --- LangSmith (Optional — for NB21, NB24, Capstone 4) ---
# Get your key at https://smith.langchain.com
LANGCHAIN_API_KEY=ls-your-langsmith-key-here
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=agents-course

# --- Azure AD / LiteLLM Proxy (Optional) ---
# Use this if your org provides a LiteLLM proxy secured behind Azure AD.
# The OAuth2 client-credentials flow fetches a token, which is used as the API key.
AZURE_TENANT_ID=your-azure-tenant-id
AZURE_CLIENT_ID=your-azure-client-id
AZURE_CLIENT_SECRET=your-azure-client-secret
AZURE_SCOPE=api://your-litellm-app-id/.default
LITELLM_PROXY_URL=https://your-litellm-proxy.example.com

# --- Zscaler / Corporate SSL Certificate (Optional) ---
# If behind a corporate proxy (Zscaler, Netskope, etc.), SSL calls will fail
# unless you point to your org's root CA certificate (.pem file).
# Set ONE of these to the absolute path of your .pem file:
# REQUESTS_CA_BUNDLE=C:/certs/zscaler_root_ca.pem
# SSL_CERT_FILE=C:/certs/zscaler_root_ca.pem
